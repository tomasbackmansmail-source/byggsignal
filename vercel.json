{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "api/cron-scrape.js", "use": "@vercel/node" },
    { "src": "api/cron/notify.js", "use": "@vercel/node" },
    { "src": "api/webhook/stripe.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/cron-scrape", "dest": "/api/cron-scrape.js" },
    { "src": "/api/cron/notify", "dest": "/api/cron/notify.js" },
    { "src": "/api/webhook/stripe", "dest": "/api/webhook/stripe.js" },
    { "src": "/webhook/stripe", "dest": "/api/webhook/stripe.js" },
    { "src": "/strategi", "dest": "/public/strategi.html" },
    { "src": "/(.*)", "dest": "/server.js" }
  ],
  "crons": [
    { "path": "/api/cron-scrape", "schedule": "0 6 * * 1-5" },
    { "path": "/api/cron/notify", "schedule": "0 15 * * *" }
  ]
}
