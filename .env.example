# Scraper-service autentisering (välj ett slumpmässigt långt värde)
SCRAPER_SECRET=

# Vercel Cron autentisering (välj ett slumpmässigt långt värde)
CRON_SECRET=

# URL till Railway scraper-service (t.ex. https://byggsignal-scraper.up.railway.app)
RAILWAY_SCRAPER_URL=

# Supabase
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_KEY=

# Stripe (för web-servern)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Scraper-service port (Railway sätter PORT automatiskt)
PORT=3001

# Sätt till "true" för att trigga scraping direkt vid uppstart
SCRAPE_ON_START=false
