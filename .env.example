# Scraper-service autentisering (välj ett slumpmässigt långt värde)
SCRAPER_SECRET=

# Supabase
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_KEY=

# Stripe (för web-servern)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Scraper-service port (Railway sätter PORT automatiskt)
PORT=3001

# Sätt till "true" för att trigga scraping direkt vid uppstart
SCRAPE_ON_START=false
